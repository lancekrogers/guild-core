package storage

import (
	"context"
	"testing"

	"github.com/guild-ventures/guild-core/pkg/kanban"
	"github.com/guild-ventures/guild-core/pkg/registry"
	"github.com/guild-ventures/guild-core/pkg/storage"
	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"
)

func TestKanbanSQLiteIntegration(t *testing.T) {
	ctx := context.Background()

	t.Run("Kanban Manager creates board in SQLite", func(t *testing.T) {
		// Initialize SQLite storage
		kanbanAdapter, memoryStoreAdapter, err := storage.InitializeSQLiteStorageForTests(ctx)
		require.NoError(t, err)

		// Create kanban manager with the kanban adapter (SQLite mode)
		manager, err := kanban.NewManagerWithRegistry(kanbanAdapter.(kanban.ComponentRegistry))
		require.NoError(t, err)
		require.NotNil(t, manager)

		// Create board - this should create a campaign in SQLite
		board, err := manager.CreateBoard(ctx, "SQLite Test Board", "Test board using SQLite storage")
		require.NoError(t, err)
		require.NotNil(t, board)

		assert.Equal(t, "SQLite Test Board", board.Name)
		assert.Equal(t, "Test board using SQLite storage", board.Description)
		assert.NotEmpty(t, board.ID)

		// Verify the board was saved as a campaign in SQLite
		storageRegistry := kanbanAdapter.(*storage.KanbanComponentRegistryAdapter).GetStorageRegistry()
		campaignRepo := storageRegistry.GetCampaignRepository()
		campaign, err := campaignRepo.GetCampaign(ctx, board.ID)
		require.NoError(t, err)
		assert.Equal(t, board.Name, campaign.Name)
		assert.Equal(t, "active", campaign.Status)
	})

	t.Run("Board creates tasks in SQLite", func(t *testing.T) {
		// Initialize SQLite storage
		kanbanAdapter, memoryStoreAdapter, err := storage.InitializeSQLiteStorageForTests(ctx)
		require.NoError(t, err)

		// Create kanban manager and board
		manager, err := kanban.NewManagerWithRegistry(kanbanAdapter.(kanban.ComponentRegistry))
		require.NoError(t, err)

		board, err := manager.CreateBoard(ctx, "Task Test Board", "Board for testing task creation")
		require.NoError(t, err)

		// Create a task - this should create a commission and task in SQLite
		task, err := board.CreateTask(ctx, "Test Task", "This is a test task for SQLite")
		require.NoError(t, err)
		require.NotNil(t, task)

		assert.Equal(t, "Test Task", task.Title)
		assert.Equal(t, "This is a test task for SQLite", task.Description)
		assert.NotEmpty(t, task.ID)

		// Verify the task was saved in SQLite
		storageRegistry := kanbanAdapter.(*storage.KanbanComponentRegistryAdapter).GetStorageRegistry()
		taskRepo := storageRegistry.GetTaskRepository()
		sqliteTask, err := taskRepo.GetTask(ctx, task.ID)
		require.NoError(t, err)
		assert.Equal(t, task.Title, sqliteTask.Title)
		assert.Equal(t, task.Description, *sqliteTask.Description)
		assert.Equal(t, string(task.Status), sqliteTask.Status)

		// Verify the commission was created
		commissionRepo := storageRegistry.GetCommissionRepository()
		expectedCommissionID := board.ID + "-default-commission"
		commission, err := commissionRepo.GetCommission(ctx, expectedCommissionID)
		require.NoError(t, err)
		assert.Equal(t, board.Name+" Tasks", commission.Title)
		assert.Equal(t, board.ID, commission.CampaignID)

		// Verify foreign key relationships
		assert.Equal(t, expectedCommissionID, sqliteTask.CommissionID)
	})

	t.Run("Task events are recorded in SQLite", func(t *testing.T) {
		// Initialize SQLite storage
		kanbanAdapter, memoryStoreAdapter, err := storage.InitializeSQLiteStorageForTests(ctx)
		require.NoError(t, err)

		// Create kanban manager, board, and task
		manager, err := kanban.NewManagerWithRegistry(kanbanAdapter.(kanban.ComponentRegistry))
		require.NoError(t, err)

		board, err := manager.CreateBoard(ctx, "Event Test Board", "Board for testing events")
		require.NoError(t, err)

		task, err := board.CreateTask(ctx, "Event Test Task", "Task for testing events")
		require.NoError(t, err)

		// Check that task creation event was recorded
		storageRegistry := kanbanAdapter.(*storage.KanbanComponentRegistryAdapter).GetStorageRegistry()
		taskRepo := storageRegistry.GetTaskRepository()
		events, err := taskRepo.GetTaskHistory(ctx, task.ID)
		require.NoError(t, err)
		assert.Len(t, events, 1, "Should have exactly one creation event")

		event := events[0]
		assert.Equal(t, task.ID, event.TaskID)
		assert.Equal(t, "created", event.EventType)
		assert.Equal(t, "Task created on board", *event.Reason)
		assert.NotZero(t, event.CreatedAt)
	})

	t.Run("Full workflow: Campaign → Commission → Task hierarchy", func(t *testing.T) {
		// Initialize SQLite storage
		kanbanAdapter, memoryStoreAdapter, err := storage.InitializeSQLiteStorageForTests(ctx)
		require.NoError(t, err)

		// Create the complete hierarchy
		manager, err := kanban.NewManagerWithRegistry(kanbanAdapter.(kanban.ComponentRegistry))
		require.NoError(t, err)

		// Board = Campaign
		board, err := manager.CreateBoard(ctx, "Project Alpha", "Main project board")
		require.NoError(t, err)

		// Tasks automatically create commission
		task1, err := board.CreateTask(ctx, "Implement feature A", "First feature")
		require.NoError(t, err)

		task2, err := board.CreateTask(ctx, "Implement feature B", "Second feature")
		require.NoError(t, err)

		// Verify the complete relationship hierarchy in SQLite
		storageRegistry := kanbanAdapter.(*storage.KanbanComponentRegistryAdapter).GetStorageRegistry()
		campaignRepo := storageRegistry.GetCampaignRepository()
		commissionRepo := storageRegistry.GetCommissionRepository()
		taskRepo := storageRegistry.GetTaskRepository()

		// 1. Campaign exists
		campaign, err := campaignRepo.GetCampaign(ctx, board.ID)
		require.NoError(t, err)
		assert.Equal(t, "Project Alpha", campaign.Name)

		// 2. Commission exists and links to campaign
		commissionID := board.ID + "-default-commission"
		commission, err := commissionRepo.GetCommission(ctx, commissionID)
		require.NoError(t, err)
		assert.Equal(t, board.ID, commission.CampaignID)

		// 3. Tasks exist and link to commission
		sqliteTask1, err := taskRepo.GetTask(ctx, task1.ID)
		require.NoError(t, err)
		assert.Equal(t, commissionID, sqliteTask1.CommissionID)

		sqliteTask2, err := taskRepo.GetTask(ctx, task2.ID)
		require.NoError(t, err)
		assert.Equal(t, commissionID, sqliteTask2.CommissionID)

		// 4. Query tasks by commission (relationship working)
		commissionTasks, err := taskRepo.ListTasksByCommission(ctx, commissionID)
		require.NoError(t, err)
		assert.Len(t, commissionTasks, 2, "Should have both tasks")

		// 5. Verify task IDs match
		taskIDs := make([]string, len(commissionTasks))
		for i, t := range commissionTasks {
			taskIDs[i] = t.ID
		}
		assert.Contains(t, taskIDs, task1.ID)
		assert.Contains(t, taskIDs, task2.ID)
	})
}