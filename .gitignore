##############################
# Guild-Core .gitignore
# Enterprise-grade open source Go project
##############################

### Go ###
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Build output
bin/
dist/
build/

# Test binaries
*.test
*.test.exe

# Output of the go coverage tool
*.out
*.prof
*.cover
coverage/
coverage.html
coverage.xml
.coverage

# Dependency directories
vendor/

# Go workspace files
go.work
go.work.sum

# Go module cache
go.sum.old

### Testing ###
# Test output directories
test_output/
test_results/
testdata/output/
.test-project*/
.test-guild*/
manual-test/

# Test artifacts
.test-results.tmp
.ci-test-results.json
.test-timing.tmp
*.test.log
test.log

# Makefile test tracking files
.build_pass
.build_fail
.unit_pass
.unit_fail
.integration_pass
.integration_fail

# Benchmark results
*.bench
benchmarks/

### Development Artifacts ###
# Work in progress files (should not be committed)
*.wip
*.todo
*.fixme

# Backup files
*.backup
*.bak
*.orig
*~
*.swp
*.swo
*.swn

# Temporary files
*.tmp
*.temp
tmp/
temp/

# Old/disabled code (should be cleaned before commit)
*.old
*.disabled
*.needs_work

# Protobuf generation artifacts (prevent github.com/ directory creation)
github.com/
*/github.com/

### Guild-Specific ###
# Guild project-local directory (runtime data)
.guild/
.campaign/

# Claude AI configuration (if present)
.claude/
**/.claude/settings.local.json

# Task runner
.task/

### IDE and Editor ###
# Visual Studio Code
.vscode/
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json.example

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
Session.vim
Sessionx.vim
.netrwhist
tags
[._]*.un~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini

# Linux
.directory
.Trash-*

### Environment and Secrets ###
# Environment variables
.env
.env.*
!.env.example
!.env.template

# Secrets (never commit)
*.pem
*.key
*.p12
*.pfx
.secrets
secrets/

# API keys and credentials
.netrc
.authinfo
.pgpass

### Logs and Debug ###
# Log files
*.log
logs/
log/

# Debug files
/debug/
*.debug
debug.test
__debug_bin

### Documentation ###
# Generated documentation
_book/
.docusaurus/
site/

# API documentation
api/swagger-ui/
api/redoc-static.html

### CI/CD ###
# GitHub Actions
.github/workflows/local/

# Pre-commit
.pre-commit-config.yaml.backup

# Secrets baseline (DO commit this - it's the allowlist)
!.secrets.baseline

### Miscellaneous ###
# Archives
*.tar
*.tar.gz
*.zip
*.7z
*.rar

# Database files (except migrations)
*.db
*.sqlite
*.sqlite3
!db/migrations/*.sql

# Binary data
*.dat
*.bin

# Cache
.cache/
/cache/

# Node.js (if frontend assets exist)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python (for any Python scripts)
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
env/

### Project-Specific Excludes ###
# Add any project-specific patterns here

# Keep .gitkeep files
!.gitkeep

# Allow example configurations
!examples/**/*.yaml
!examples/**/*.yml
!examples/**/*.json
test-*/
hash-test/

# Coverage files

# Build artifacts
bin/guild
.test-*.tmp

