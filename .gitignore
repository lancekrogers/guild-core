# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/
/guild
/guild.exe
layered_prompt_example

# Test binary, built with `go test -c`
*.test
.test-*
# Test temporary files (but allow Go test source files like *_test.go)
test_output/
test_results/

# Demo and example binaries
guild_hall
rag_test
prompt_link_parser

# Output of the go coverage tool, specifically when used with LiteIDE
*.out
coverage/
coverage.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Ignore potential sensitive claude data
.claude/history/
.claude/config.json
.claude/auth.json
.claude/
.task/

# Guild project-local directory (similar to .git/)
.guild/


**/.claude/settings.local.json
*.wip

# Test artifacts
.test-results.tmp
.ci-test-results.json
.test-timing.tmp

# Development artifacts - NEVER COMMIT (Enterprise Standards)
*.disabled
*.old
*.needs_work
*.backup
*.tmp
*.bak
*~


# IDE and OS artifacts
.DS_Store
Thumbs.db
.vscode/
.idea/

