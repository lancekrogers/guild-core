// StorageRegistryAdapter adapts the storage StorageRegistry to the registry StorageRegistry interface
type StorageRegistryAdapter struct {
	taskRepo       registry.TaskRepository
	campaignRepo   registry.CampaignRepository
	commissionRepo registry.CommissionRepository
	agentRepo      registry.AgentRepository
	memoryStore    registry.MemoryStore
}

func NewStorageRegistryAdapter(
	taskRepo TaskRepository,
	campaignRepo CampaignRepository,
	commissionRepo CommissionRepository,
	agentRepo AgentRepository,
	memoryStore registry.MemoryStore,
) registry.StorageRegistry {
	return &StorageRegistryAdapter{
		taskRepo:       NewTaskRepositoryAdapter(taskRepo),
		campaignRepo:   NewCampaignRepositoryAdapter(campaignRepo),
		commissionRepo: NewCommissionRepositoryAdapter(commissionRepo),
		agentRepo:      NewAgentRepositoryAdapter(agentRepo),
		memoryStore:    memoryStore,
	}
}

func (s *StorageRegistryAdapter) RegisterTaskRepository(repo registry.TaskRepository) error {
	s.taskRepo = repo
	return nil
}

func (s *StorageRegistryAdapter) GetTaskRepository() registry.TaskRepository {
	return s.taskRepo
}

func (s *StorageRegistryAdapter) RegisterCampaignRepository(repo registry.CampaignRepository) error {
	s.campaignRepo = repo
	return nil
}

func (s *StorageRegistryAdapter) GetCampaignRepository() registry.CampaignRepository {
	return s.campaignRepo
}

func (s *StorageRegistryAdapter) RegisterCommissionRepository(repo registry.CommissionRepository) error {
	s.commissionRepo = repo
	return nil
}

func (s *StorageRegistryAdapter) GetCommissionRepository() registry.CommissionRepository {
	return s.commissionRepo
}

func (s *StorageRegistryAdapter) RegisterAgentRepository(repo registry.AgentRepository) error {
	s.agentRepo = repo
	return nil
}

func (s *StorageRegistryAdapter) GetAgentRepository() registry.AgentRepository {
	return s.agentRepo
}

func (s *StorageRegistryAdapter) GetMemoryStore() registry.MemoryStore {
	return s.memoryStore
}