func (a *TaskRepositoryAdapter) AssignTask(ctx context.Context, taskID, agentID string) error {
	return a.repo.AssignTask(ctx, taskID, agentID)
}

func (a *TaskRepositoryAdapter) UpdateTaskStatus(ctx context.Context, taskID, status string) error {
	return a.repo.UpdateTaskStatus(ctx, taskID, status)
}

func (a *TaskRepositoryAdapter) UpdateTaskColumn(ctx context.Context, taskID, column string) error {
	return a.repo.UpdateTaskColumn(ctx, taskID, column)
}

func (a *TaskRepositoryAdapter) RecordTaskEvent(ctx context.Context, event *registry.TaskEvent) error {
	storageEvent := &TaskEvent{
		ID:        event.ID,
		TaskID:    event.TaskID,
		AgentID:   event.AgentID,
		EventType: event.EventType,
		OldValue:  event.OldValue,
		NewValue:  event.NewValue,
		Reason:    event.Reason,
		CreatedAt: event.CreatedAt,
	}
	return a.repo.RecordTaskEvent(ctx, storageEvent)
}

func (a *TaskRepositoryAdapter) GetTaskHistory(ctx context.Context, taskID string) ([]*registry.TaskEvent, error) {
	events, err := a.repo.GetTaskHistory(ctx, taskID)
	if err != nil {
		return nil, err
	}
	
	result := make([]*registry.TaskEvent, len(events))
	for i, event := range events {
		result[i] = &registry.TaskEvent{
			ID:        event.ID,
			TaskID:    event.TaskID,
			AgentID:   event.AgentID,
			EventType: event.EventType,
			OldValue:  event.OldValue,
			NewValue:  event.NewValue,
			Reason:    event.Reason,
			CreatedAt: event.CreatedAt,
		}
	}
	return result, nil
}

func (a *TaskRepositoryAdapter) GetAgentWorkload(ctx context.Context) ([]*registry.AgentWorkload, error) {
	workloads, err := a.repo.GetAgentWorkload(ctx)
	if err != nil {
		return nil, err
	}
	
	result := make([]*registry.AgentWorkload, len(workloads))
	for i, workload := range workloads {
		result[i] = &registry.AgentWorkload{
			ID:          workload.ID,
			Name:        workload.Name,
			TaskCount:   workload.TaskCount,
			ActiveTasks: workload.ActiveTasks,
		}
	}
	return result, nil
}

// CampaignRepositoryAdapter adapts the storage CampaignRepository to the registry CampaignRepository interface
type CampaignRepositoryAdapter struct {
	repo CampaignRepository
}

func NewCampaignRepositoryAdapter(repo CampaignRepository) registry.CampaignRepository {
	return &CampaignRepositoryAdapter{repo: repo}
}

func (a *CampaignRepositoryAdapter) CreateCampaign(ctx context.Context, campaign *registry.Campaign) error {
	storageCampaign := &Campaign{
		ID:        campaign.ID,
		Name:      campaign.Name,
		Status:    campaign.Status,
		CreatedAt: campaign.CreatedAt,
		UpdatedAt: campaign.UpdatedAt,
	}
	return a.repo.CreateCampaign(ctx, storageCampaign)
}

func (a *CampaignRepositoryAdapter) GetCampaign(ctx context.Context, id string) (*registry.Campaign, error) {
	campaign, err := a.repo.GetCampaign(ctx, id)
	if err != nil {
		return nil, err
	}
	
	return &registry.Campaign{
		ID:        campaign.ID,
		Name:      campaign.Name,
		Status:    campaign.Status,
		CreatedAt: campaign.CreatedAt,
		UpdatedAt: campaign.UpdatedAt,
	}, nil
}

func (a *CampaignRepositoryAdapter) UpdateCampaignStatus(ctx context.Context, id, status string) error {
	return a.repo.UpdateCampaignStatus(ctx, id, status)
}

func (a *CampaignRepositoryAdapter) DeleteCampaign(ctx context.Context, id string) error {
	return a.repo.DeleteCampaign(ctx, id)
}

func (a *CampaignRepositoryAdapter) ListCampaigns(ctx context.Context) ([]*registry.Campaign, error) {
	campaigns, err := a.repo.ListCampaigns(ctx)
	if err != nil {
		return nil, err
	}
	
	result := make([]*registry.Campaign, len(campaigns))
	for i, campaign := range campaigns {
		result[i] = &registry.Campaign{
			ID:        campaign.ID,
			Name:      campaign.Name,
			Status:    campaign.Status,
			CreatedAt: campaign.CreatedAt,
			UpdatedAt: campaign.UpdatedAt,
		}
	}
	return result, nil
}

// CommissionRepositoryAdapter adapts the storage CommissionRepository to the registry CommissionRepository interface
type CommissionRepositoryAdapter struct {
	repo CommissionRepository
}

func NewCommissionRepositoryAdapter(repo CommissionRepository) registry.CommissionRepository {
	return &CommissionRepositoryAdapter{repo: repo}
}

func (a *CommissionRepositoryAdapter) CreateCommission(ctx context.Context, commission *registry.Commission) error {
	storageCommission := &Commission{
		ID:          commission.ID,
		CampaignID:  commission.CampaignID,
		Title:       commission.Title,
		Description: commission.Description,
		Domain:      commission.Domain,
		Context:     commission.Context,
		Status:      commission.Status,
		CreatedAt:   commission.CreatedAt,
	}
	return a.repo.CreateCommission(ctx, storageCommission)
}

func (a *CommissionRepositoryAdapter) GetCommission(ctx context.Context, id string) (*registry.Commission, error) {
	commission, err := a.repo.GetCommission(ctx, id)
	if err != nil {
		return nil, err
	}
	
	return &registry.Commission{
		ID:          commission.ID,
		CampaignID:  commission.CampaignID,
		Title:       commission.Title,
		Description: commission.Description,
		Domain:      commission.Domain,
		Context:     commission.Context,
		Status:      commission.Status,
		CreatedAt:   commission.CreatedAt,
	}, nil
}

func (a *CommissionRepositoryAdapter) UpdateCommissionStatus(ctx context.Context, id, status string) error {
	return a.repo.UpdateCommissionStatus(ctx, id, status)
}

func (a *CommissionRepositoryAdapter) DeleteCommission(ctx context.Context, id string) error {
	return a.repo.DeleteCommission(ctx, id)
}

func (a *CommissionRepositoryAdapter) ListCommissionsByCampaign(ctx context.Context, campaignID string) ([]*registry.Commission, error) {
	commissions, err := a.repo.ListCommissionsByCampaign(ctx, campaignID)
	if err != nil {
		return nil, err
	}
	
	result := make([]*registry.Commission, len(commissions))
	for i, commission := range commissions {
		result[i] = &registry.Commission{
			ID:          commission.ID,
			CampaignID:  commission.CampaignID,
			Title:       commission.Title,
			Description: commission.Description,
			Domain:      commission.Domain,
			Context:     commission.Context,
			Status:      commission.Status,
			CreatedAt:   commission.CreatedAt,
		}
	}
	return result, nil
}

