package storage

import (
	"context"

	"github.com/guild-ventures/guild-core/pkg/registry"
)

// TaskRepositoryAdapter adapts the storage TaskRepository to the registry TaskRepository interface
type TaskRepositoryAdapter struct {
	repo TaskRepository
}

func NewTaskRepositoryAdapter(repo TaskRepository) registry.TaskRepository {
	return &TaskRepositoryAdapter{repo: repo}
}

func (a *TaskRepositoryAdapter) CreateTask(ctx context.Context, task *registry.StorageTask) error {
	storageTask := &Task{
		ID:              task.ID,
		CommissionID:    task.CommissionID,
		AssignedAgentID: task.AssignedAgentID,
		Title:           task.Title,
		Description:     task.Description,
		Status:          task.Status,
		Column:          task.Column,
		StoryPoints:     task.StoryPoints,
		Metadata:        task.Metadata,
		CreatedAt:       task.CreatedAt,
		UpdatedAt:       task.UpdatedAt,
		AgentName:       task.AgentName,
		AgentType:       task.AgentType,
	}
	return a.repo.CreateTask(ctx, storageTask)
}

func (a *TaskRepositoryAdapter) GetTask(ctx context.Context, id string) (*registry.StorageTask, error) {
	task, err := a.repo.GetTask(ctx, id)
	if err != nil {
		return nil, err
	}
	
	return &registry.StorageTask{
		ID:              task.ID,
		CommissionID:    task.CommissionID,
		AssignedAgentID: task.AssignedAgentID,
		Title:           task.Title,
		Description:     task.Description,
		Status:          task.Status,
		Column:          task.Column,
		StoryPoints:     task.StoryPoints,
		Metadata:        task.Metadata,
		CreatedAt:       task.CreatedAt,
		UpdatedAt:       task.UpdatedAt,
		AgentName:       task.AgentName,
		AgentType:       task.AgentType,
	}, nil
}

func (a *TaskRepositoryAdapter) UpdateTask(ctx context.Context, task *registry.StorageTask) error {
	storageTask := &Task{
		ID:              task.ID,
		CommissionID:    task.CommissionID,
		AssignedAgentID: task.AssignedAgentID,
		Title:           task.Title,
		Description:     task.Description,
		Status:          task.Status,
		Column:          task.Column,
		StoryPoints:     task.StoryPoints,
		Metadata:        task.Metadata,
		CreatedAt:       task.CreatedAt,
		UpdatedAt:       task.UpdatedAt,
		AgentName:       task.AgentName,
		AgentType:       task.AgentType,
	}
	return a.repo.UpdateTask(ctx, storageTask)
}

func (a *TaskRepositoryAdapter) DeleteTask(ctx context.Context, id string) error {
	return a.repo.DeleteTask(ctx, id)
}

func (a *TaskRepositoryAdapter) ListTasks(ctx context.Context) ([]*registry.StorageTask, error) {
	tasks, err := a.repo.ListTasks(ctx)
	if err != nil {
		return nil, err
	}
	
	result := make([]*registry.StorageTask, len(tasks))
	for i, task := range tasks {
		result[i] = &registry.StorageTask{
			ID:              task.ID,
			CommissionID:    task.CommissionID,
			AssignedAgentID: task.AssignedAgentID,
			Title:           task.Title,
			Description:     task.Description,
			Status:          task.Status,
			Column:          task.Column,
			StoryPoints:     task.StoryPoints,
			Metadata:        task.Metadata,
			CreatedAt:       task.CreatedAt,
			UpdatedAt:       task.UpdatedAt,
			AgentName:       task.AgentName,
			AgentType:       task.AgentType,
		}
	}
	return result, nil
}

func (a *TaskRepositoryAdapter) ListTasksByStatus(ctx context.Context, status string) ([]*registry.StorageTask, error) {
	tasks, err := a.repo.ListTasksByStatus(ctx, status)
	if err != nil {
		return nil, err
	}
	
	result := make([]*registry.StorageTask, len(tasks))
	for i, task := range tasks {
