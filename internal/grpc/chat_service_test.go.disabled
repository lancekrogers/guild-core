// MockEventBus implements EventBus for testing
type MockEventBus struct {
	mock.Mock
}

func (m *MockEventBus) Publish(event interface{}) {
	m.Called(event)
}

func (m *MockEventBus) Subscribe(eventType string, handler func(event interface{})) {
	m.Called(eventType, handler)
}

func TestNewChatService(t *testing.T) {
	tests := []struct {
		name        string
		setupMocks  func() (registry.ComponentRegistry, EventBus)
		expectError bool
	}{
		{
			name: "successful creation with valid registry",
			setupMocks: func() (registry.ComponentRegistry, EventBus) {
				mockRegistry := &MockComponentRegistry{}
				mockEventBus := &MockEventBus{}
				return mockRegistry, mockEventBus
			},
			expectError: false,
		},
		{
			name: "creation with nil registry should still work",
			setupMocks: func() (registry.ComponentRegistry, EventBus) {
				mockEventBus := &MockEventBus{}
				return nil, mockEventBus
			},
			expectError: false,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			registry, eventBus := tt.setupMocks()
			
			service := NewChatService(registry, eventBus)
			
			assert.NotNil(t, service)
			assert.NotNil(t, service.logger)
			assert.NotNil(t, service.sessions)
			assert.NotNil(t, service.subscribers)
			assert.Equal(t, registry, service.registry)
			assert.Equal(t, eventBus, service.eventBus)
		})
	}
}

func TestChatService_CreateChatSession(t *testing.T) {
	tests := []struct {
		name        string
		request     *pb.CreateChatSessionRequest
		setupMocks  func() (registry.ComponentRegistry, EventBus)
		expectError bool
		validate    func(t *testing.T, session *pb.ChatSession, service *ChatService)
	}{
		{
			name: "create session successfully",
			request: &pb.CreateChatSessionRequest{
				Name:       "Test Session",
				AgentIds:   []string{"agent1", "agent2"},
				CampaignId: "campaign123",
				Context: &pb.SessionContext{
					ProjectPath: "/test/project",
				},
				Metadata: map[string]string{
					"test": "value",
				},
			},
			setupMocks: func() (registry.ComponentRegistry, EventBus) {
				mockRegistry := &MockComponentRegistry{}
				mockEventBus := &MockEventBus{}
				
				// Mock that agent registry is not available (common case)
				mockRegistry.On("Agents").Return(nil)
				
				return mockRegistry, mockEventBus
			},
			expectError: false,
			validate: func(t *testing.T, session *pb.ChatSession, service *ChatService) {
				assert.Equal(t, "Test Session", session.Name)
				assert.Equal(t, []string{"agent1", "agent2"}, session.AgentIds)
				assert.Equal(t, "campaign123", session.CampaignId)
				assert.Equal(t, pb.ChatSession_ACTIVE, session.Status)
				assert.NotEmpty(t, session.Id)
				assert.NotNil(t, session.Context)
				assert.Equal(t, "/test/project", session.Context.ProjectPath)
				
				// Verify session is stored in service
				assert.Contains(t, service.sessions, session.Id)
			},
		},
		{
			name: "create session with empty name",
			request: &pb.CreateChatSessionRequest{
				Name:     "", // Empty name should still work
				AgentIds: []string{},
			},
			setupMocks: func() (registry.ComponentRegistry, EventBus) {
				mockRegistry := &MockComponentRegistry{}
				mockEventBus := &MockEventBus{}
				mockRegistry.On("Agents").Return(nil)
				return mockRegistry, mockEventBus
			},
			expectError: false,
			validate: func(t *testing.T, session *pb.ChatSession, service *ChatService) {
				assert.Equal(t, "", session.Name)
				assert.Empty(t, session.AgentIds)
				assert.NotEmpty(t, session.Id) // ID should still be generated
			},
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			registry, eventBus := tt.setupMocks()
			service := NewChatService(registry, eventBus)
			
			ctx := context.Background()
			session, err := service.CreateChatSession(ctx, tt.request)
			
			if tt.expectError {
				assert.Error(t, err)
				assert.Nil(t, session)
			} else {
				assert.NoError(t, err)
				assert.NotNil(t, session)
				if tt.validate != nil {
					tt.validate(t, session, service)
				}
			}
		})
	}
}

func TestChatService_EndChatSession(t *testing.T) {
	tests := []struct {
		name        string
		sessionID   string
		reason      string
		setupService func() *ChatService
		expectError bool
		validate    func(t *testing.T, response *pb.EndChatSessionResponse, service *ChatService)
	}{
		{
			name:      "end existing session",
			sessionID: "test-session-1",
			reason:    "User requested",
			setupService: func() *ChatService {
				mockRegistry := &MockComponentRegistry{}
				mockEventBus := &MockEventBus{}
				service := NewChatService(mockRegistry, mockEventBus)
				
				// Add a test session
				session := &ChatSession{
					ID:           "test-session-1",
					Name:         "Test Session",
					Status:       pb.ChatSession_ACTIVE,
					CreatedAt:    time.Now(),
					LastActivity: time.Now(),
					agents:       make(map[string]agent.Agent),
					messages:     make([]*pb.ChatMessage, 0),
					toolExecutions: make(map[string]*pb.ToolExecution),
					streams:      make(map[string]pb.ChatService_ChatServer),
				}
				service.sessions["test-session-1"] = session
				
				return service
			},
			expectError: false,
			validate: func(t *testing.T, response *pb.EndChatSessionResponse, service *ChatService) {
				assert.True(t, response.Success)
				assert.Equal(t, "Session ended successfully", response.Message)
				assert.NotNil(t, response.Summary)
				
				// Session should be removed from service
				assert.NotContains(t, service.sessions, "test-session-1")
			},
		},
		{
			name:      "end non-existent session",
			sessionID: "non-existent",
			reason:    "Test",
			setupService: func() *ChatService {
				mockRegistry := &MockComponentRegistry{}
				mockEventBus := &MockEventBus{}
				return NewChatService(mockRegistry, mockEventBus)
			},
			expectError: true,
			validate:    nil,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			service := tt.setupService()
			
			ctx := context.Background()
			request := &pb.EndChatSessionRequest{
				SessionId: tt.sessionID,
				Reason:    tt.reason,
			}
			
			response, err := service.EndChatSession(ctx, request)
			
			if tt.expectError {
				assert.Error(t, err)
				assert.Nil(t, response)
			} else {
				assert.NoError(t, err)
				assert.NotNil(t, response)
				if tt.validate != nil {
					tt.validate(t, response, service)
				}
			}
		})
	}
}

func TestChatService_ListChatSessions(t *testing.T) {
	tests := []struct {
		name         string
		request      *pb.ListChatSessionsRequest
		setupService func() *ChatService
		validate     func(t *testing.T, response *pb.ListChatSessionsResponse)
	}{
		{
			name: "list all sessions",
			request: &pb.ListChatSessionsRequest{
				IncludeEnded: true,
			},
			setupService: func() *ChatService {
				mockRegistry := &MockComponentRegistry{}
				mockEventBus := &MockEventBus{}
				service := NewChatService(mockRegistry, mockEventBus)
				
				// Add test sessions
				session1 := &ChatSession{
					ID:         "session-1",
					Name:       "Active Session",
					Status:     pb.ChatSession_ACTIVE,
					CampaignID: "campaign-1",
				}
				session2 := &ChatSession{
					ID:         "session-2",
					Name:       "Ended Session",
					Status:     pb.ChatSession_ENDED,
					CampaignID: "campaign-2",
				}
				
				service.sessions["session-1"] = session1
				service.sessions["session-2"] = session2
				
				return service
			},
			validate: func(t *testing.T, response *pb.ListChatSessionsResponse) {
				assert.Len(t, response.Sessions, 2)
				assert.Equal(t, int32(2), response.TotalCount)
				
				// Verify session data
				sessionMap := make(map[string]*pb.ChatSession)
				for _, session := range response.Sessions {
					sessionMap[session.Id] = session
				}
				
				assert.Contains(t, sessionMap, "session-1")
				assert.Contains(t, sessionMap, "session-2")
				assert.Equal(t, "Active Session", sessionMap["session-1"].Name)
				assert.Equal(t, "Ended Session", sessionMap["session-2"].Name)
			},
		},
		{
			name: "list only active sessions",
			request: &pb.ListChatSessionsRequest{
				IncludeEnded: false,
			},
			setupService: func() *ChatService {
				mockRegistry := &MockComponentRegistry{}
				mockEventBus := &MockEventBus{}
				service := NewChatService(mockRegistry, mockEventBus)
				
				// Add test sessions
				session1 := &ChatSession{
					ID:     "session-1",
					Status: pb.ChatSession_ACTIVE,
				}
				session2 := &ChatSession{
					ID:     "session-2",
					Status: pb.ChatSession_ENDED,
				}
				
				service.sessions["session-1"] = session1
				service.sessions["session-2"] = session2
				
				return service
			},
			validate: func(t *testing.T, response *pb.ListChatSessionsResponse) {
				assert.Len(t, response.Sessions, 1)
				assert.Equal(t, int32(1), response.TotalCount)
				assert.Equal(t, "session-1", response.Sessions[0].Id)
			},
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			service := tt.setupService()
			
			ctx := context.Background()
			response, err := service.ListChatSessions(ctx, tt.request)
			
			assert.NoError(t, err)
			assert.NotNil(t, response)
			if tt.validate != nil {
				tt.validate(t, response)
			}
		})
	}
}

func TestGenerateSessionID(t *testing.T) {
	// Test that session IDs are unique and follow expected format
	id1 := generateSessionID()
	time.Sleep(1 * time.Millisecond) // Ensure different timestamps
	id2 := generateSessionID()
	
	assert.NotEqual(t, id1, id2)
	assert.Contains(t, id1, "chat_")
	assert.Contains(t, id2, "chat_")
	
	// Test format
	assert.Regexp(t, `^chat_\d+$`, id1)
	assert.Regexp(t, `^chat_\d+$`, id2)
}

func TestChatService_GetAgentName(t *testing.T) {
	tests := []struct {
		name        string
		agentID     string
		setupMocks  func() registry.ComponentRegistry
		expectedName string
	}{
		{
			name:    "agent registry not available",
			agentID: "agent1",
			setupMocks: func() registry.ComponentRegistry {
				mockRegistry := &MockComponentRegistry{}
				mockRegistry.On("Agents").Return(nil)
				return mockRegistry
			},
			expectedName: "agent1", // Should return agentID when registry not available
		},
		{
			name:    "registry is nil",
			agentID: "agent1",
			setupMocks: func() registry.ComponentRegistry {
				return nil
			},
			expectedName: "agent1", // Should return agentID when registry is nil
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			registry := tt.setupMocks()
			mockEventBus := &MockEventBus{}
			service := NewChatService(registry, mockEventBus)
			
			name := service.getAgentName(tt.agentID)
			assert.Equal(t, tt.expectedName, name)
		})
	}
}