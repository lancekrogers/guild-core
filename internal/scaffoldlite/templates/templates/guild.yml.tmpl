# Guild Configuration Template
# Generated by Guild Scaffold v{{ .vars.scaffold_version | default "0.1.0" }}
# Created: {{ date "2006-01-02 15:04:05" }}

guild:
  name: {{ .vars.guild_name | default .vars.campaign_name }}-guild
  description: {{ .vars.guild_description | default (printf "Development guild for %s campaign" .vars.campaign_name) }}
  
  # Guild metadata
  metadata:
    created: {{ dateISO }}
    version: {{ .vars.guild_version | default "1.0.0" }}
    campaign: {{ .vars.campaign_name }}
    guild_type: {{ .vars.guild_type | default "development" }}
    
  # Core guild settings
  settings:
    max_agents: {{ .vars.max_agents | default 8 }}
    coordination_style: {{ .vars.coordination_style | default "collaborative" }}
    decision_making: {{ .vars.decision_making | default "consensus" }}
    communication_pattern: {{ .vars.communication_pattern | default "broadcast" }}
    
  # Agent roles and assignments
  roles:
{{- range .vars.agent_roles }}
    - name: {{ .name }}
      type: {{ .type }}
      description: {{ .description }}
      responsibilities:
{{- range .responsibilities }}
        - {{ . | quote }}
{{- end }}
      capabilities:
{{- range .capabilities }}
        - {{ . | quote }}
{{- end }}
      agent_config: {{ .config_file }}
{{- end }}
      
  # Guild coordination patterns
  coordination:
    standup_schedule: {{ .vars.standup_schedule | default "daily" }}
    review_cycle: {{ .vars.review_cycle | default "weekly" }}
    planning_frequency: {{ .vars.planning_frequency | default "sprint" }}
    
    # Communication channels
    channels:
      primary: {{ .vars.primary_channel | default "guild-main" }}
      technical: {{ .vars.technical_channel | default "guild-tech" }}
      planning: {{ .vars.planning_channel | default "guild-planning" }}
      
  # Performance metrics
  metrics:
    track_velocity: {{ .vars.track_velocity | default true }}
    measure_quality: {{ .vars.measure_quality | default true }}
    monitor_collaboration: {{ .vars.monitor_collaboration | default true }}
    
  # Guild-specific configuration
{{- if .vars.guild_config }}
  custom_config:
{{ .vars.guild_config | toYAML | indent 4 }}
{{- end }}

