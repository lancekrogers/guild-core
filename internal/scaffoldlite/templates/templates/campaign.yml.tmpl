# Guild Campaign Configuration
# Generated by Guild Scaffold v{{ .vars.scaffold_version | default "0.1.0" }}
# Created: {{ date "2006-01-02 15:04:05" }}

campaign:
  name: {{ .vars.campaign_name | quote }}
  hash: {{ .vars.campaign_name | campaignHash }}
  version: {{ .vars.campaign_version | default "1.0.0" }}
  created_at: {{ dateISO }}
  
  {{- if .vars.description }}
  description: |
{{ .vars.description | indent 4 }}
  {{- end }}

  # Project information
  project:
    type: {{ .computed.project_type | default "generic" }}
    {{- if .computed.project_language }}
    language: {{ .computed.project_language }}
    {{- end }}
    {{- if .computed.project_framework }}
    framework: {{ .computed.project_framework }}
    {{- end }}
    path: {{ .vars.project_path | default "." }}

# Daemon Configuration
daemon:
  enabled: {{ .vars.daemon_enabled | default true }}
  socket_path: {{ printf "/tmp/guild-%s.sock" (.vars.campaign_name | campaignHash) }}
  auto_start: {{ .vars.daemon_auto_start | default true }}
  log_level: {{ .vars.log_level | default "info" }}
  
  # Performance settings
  performance:
    max_workers: {{ .vars.max_workers | default 4 }}
    timeout: {{ .vars.request_timeout | default "30s" }}
    memory_limit: {{ .vars.memory_limit | default "512MB" }}

# Storage Configuration  
storage:
  database:
    type: "sqlite"
    path: ".campaign/memory.db"
    auto_migrate: true
    backup_enabled: {{ .vars.backup_enabled | default true }}
    
  archives:
    path: ".campaign/archives"
    compression: {{ .vars.archive_compression | default "gzip" }}
    retention_days: {{ .vars.retention_days | default 30 }}

# Provider Configuration
providers:
  {{- range $provider, $config := .vars.providers }}
  {{ $provider }}:
{{ $config | toYAML | indent 4 }}
  {{- end }}
  
  # Default provider fallback
  {{- if empty .vars.providers }}
  anthropic:
    api_key_env: "ANTHROPIC_API_KEY"
    default_model: {{ .vars.default_model | default "claude-3-sonnet-20240229" }}
    cost_magnitude: "medium"
  {{- end }}

# Guild Configuration References
guilds:
  {{- range .vars.guilds }}
  - name: {{ .name | quote }}
    file: {{ printf "guilds/%s.yaml" .name }}
    enabled: {{ .enabled | default true }}
    {{- if .description }}
    description: {{ .description | quote }}
    {{- end }}
  {{- end }}

# Global Settings
settings:
  # Communication preferences
  communication:
    style: {{ .vars.communication_style | default "professional" }}
    verbosity: {{ .vars.verbosity | default "balanced" }}
    emoji_enabled: {{ .vars.emoji_enabled | default true }}
    
  # Workflow preferences  
  workflow:
    parallel_tasks: {{ .vars.parallel_tasks | default true }}
    auto_save: {{ .vars.auto_save | default true }}
    confirmation_required: {{ .vars.confirmation_required | default false }}
    
  # Quality settings
  quality:
    code_review_required: {{ .vars.code_review_required | default true }}
    testing_required: {{ .vars.testing_required | default true }}
    documentation_required: {{ .vars.documentation_required | default true }}

# Hooks and Extensions
{{- if .vars.hooks }}
hooks:
{{ .vars.hooks | toYAML | indent 2 }}
{{- end }}

{{- if .vars.plugins }}
plugins:
{{ .vars.plugins | toYAML | indent 2 }}
{{- end }}

# Metadata
metadata:
  created_by: {{ .runtime.user | default "guild-scaffold" }}
  scaffold_version: {{ .vars.scaffold_version | default "0.1.0" }}
  guild_version: {{ .vars.guild_version | default "unknown" }}
  
  # Environment information
  environment:
    os: {{ .runtime.os | default "unknown" }}
    arch: {{ .runtime.arch | default "unknown" }}
    go_version: {{ .runtime.go_version | default "unknown" }}
    
  # Tags for organization
  {{- if .vars.tags }}
  tags:
    {{- range .vars.tags }}
    - {{ . | quote }}
    {{- end }}
  {{- end }}

